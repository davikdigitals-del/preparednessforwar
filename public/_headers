/*
  # ============================================
  # ENTERPRISE-GRADE SECURITY HEADERS
  # Multi-Layer Protection Against All Common Attacks
  # ============================================
  
  # === LAYER 1: FRAME PROTECTION ===
  # Prevent clickjacking attacks
  X-Frame-Options: DENY
  
  # === LAYER 2: MIME SNIFFING PROTECTION ===
  # Prevent MIME type sniffing
  X-Content-Type-Options: nosniff
  
  # === LAYER 3: XSS PROTECTION ===
  # Enable XSS protection in older browsers
  X-XSS-Protection: 1; mode=block
  
  # === LAYER 4: CONTENT SECURITY POLICY ===
  # Strict CSP to prevent XSS, injection attacks
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://www.google.com https://www.gstatic.com https://accounts.google.com https://apis.google.com https://*.supabase.co https://cdn.jsdelivr.net https://www.googletagmanager.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: https: blob:; media-src 'self' https: blob:; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://www.google-analytics.com https://accounts.google.com https://api.cloudflare.com; frame-src 'self' https://www.youtube.com https://player.vimeo.com https://www.dailymotion.com https://player.twitch.tv https://open.spotify.com https://accounts.google.com; object-src 'none'; base-uri 'self'; form-action 'self' https://accounts.google.com; frame-ancestors 'none'; upgrade-insecure-requests; block-all-mixed-content;
  
  # === LAYER 5: PERMISSIONS POLICY ===
  # Disable dangerous browser features
  Permissions-Policy: camera=(), microphone=(), geolocation=(), interest-cohort=(), payment=(), usb=(), serial=(), bluetooth=(), magnetometer=(), accelerometer=(), gyroscope=(), ambient-light-sensor=()
  
  # === LAYER 6: REFERRER POLICY ===
  # Control referrer information
  Referrer-Policy: strict-origin-when-cross-origin
  
  # === LAYER 7: HTTPS ENFORCEMENT ===
  # Force HTTPS for 2 years including subdomains (HSTS)
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  
  # === LAYER 8: CACHE CONTROL ===
  # Secure caching for static assets
  Cache-Control: public, max-age=31536000, immutable
  
  # === LAYER 9: CORS POLICY ===
  # Restrict cross-origin requests
  Access-Control-Allow-Origin: https://preparednessforwar.com
  Access-Control-Allow-Methods: GET, POST, PUT, DELETE, OPTIONS
  Access-Control-Allow-Headers: Content-Type, Authorization, X-Requested-With
  Access-Control-Max-Age: 86400
  Access-Control-Allow-Credentials: true
  
  # === LAYER 10: ANTI-CLICKJACKING ===
  X-Frame-Options: DENY
  
  # === LAYER 11: INFORMATION DISCLOSURE PREVENTION ===
  # Hide server information
  X-Powered-By: 
  Server: 
  
  # === LAYER 12: DNS PREFETCH CONTROL ===
  X-DNS-Prefetch-Control: off
  
  # === LAYER 13: DOWNLOAD OPTIONS ===
  X-Download-Options: noopen
  
  # === LAYER 14: CONTENT TYPE OPTIONS ===
  X-Permitted-Cross-Domain-Policies: none

# ============================================
# ADDITIONAL PROTECTION FOR API ROUTES
# ============================================
/api/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Cache-Control: no-store, no-cache, must-revalidate, proxy-revalidate
  Pragma: no-cache
  Expires: 0
  X-Robots-Tag: noindex, nofollow

# ============================================
# PREVENT ACCESS TO SENSITIVE FILES
# ============================================
/.env
  X-Robots-Tag: noindex, nofollow
  Cache-Control: no-store, no-cache
  X-Content-Type-Options: nosniff
  Content-Security-Policy: default-src 'none'
  
/database/*
  X-Robots-Tag: noindex, nofollow
  Cache-Control: no-store, no-cache
  X-Content-Type-Options: nosniff
  Content-Security-Policy: default-src 'none'
  
/.git/*
  X-Robots-Tag: noindex, nofollow
  Cache-Control: no-store, no-cache
  X-Content-Type-Options: nosniff
  Content-Security-Policy: default-src 'none'

/node_modules/*
  X-Robots-Tag: noindex, nofollow
  Cache-Control: no-store, no-cache
  Content-Security-Policy: default-src 'none'

# ============================================
# ADMIN ROUTES - EXTRA PROTECTION
# ============================================
/admin/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Cache-Control: no-store, no-cache, must-revalidate
  X-Robots-Tag: noindex, nofollow
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://*.supabase.co; style-src 'self' 'unsafe-inline'; connect-src 'self' https://*.supabase.co wss://*.supabase.co

# ============================================
# STATIC ASSETS - AGGRESSIVE CACHING
# ============================================
/*.js
  Cache-Control: public, max-age=31536000, immutable
  
/*.css
  Cache-Control: public, max-age=31536000, immutable
  
/*.woff2
  Cache-Control: public, max-age=31536000, immutable
  
/*.woff
  Cache-Control: public, max-age=31536000, immutable
  
/*.png
  Cache-Control: public, max-age=31536000, immutable
  
/*.jpg
  Cache-Control: public, max-age=31536000, immutable
  
/*.svg
  Cache-Control: public, max-age=31536000, immutable

# ============================================
# HTML FILES - NO CACHE
# ============================================
/*.html
  Cache-Control: no-store, no-cache, must-revalidate
  Pragma: no-cache
  Expires: 0
