# ============================================================================
# PREPAREDNESS FOR WAR - ENVIRONMENT VARIABLES
# ============================================================================
# This file contains all environment variables needed for the application
# Copy this to .env for local development
# For Render deployment, add these in the Render dashboard
# ============================================================================

# ============================================================================
# FRONTEND ENVIRONMENT VARIABLES (VITE_* prefix for client-side access)
# ============================================================================

# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Stripe Configuration (Publishable key - safe for client-side)
VITE_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key

# reCAPTCHA Configuration (Site key - safe for client-side)
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_site_key

# ============================================================================
# SERVER-SIDE ENVIRONMENT VARIABLES (for Render deployment)
# ============================================================================

# Node.js Version
NODE_VERSION=20.11.0

# reCAPTCHA Secret Key (server-side only)
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key

# Stripe Secret Key (server-side only - NEVER expose to client)
STRIPE_SECRET_KEY=your_stripe_secret_key

# ============================================================================
# SUPABASE EDGE FUNCTIONS SECRETS
# ============================================================================
# These MUST be added in Supabase Dashboard → Project Settings → Edge Functions → Secrets
# DO NOT add these to .env file - they are only for Supabase Edge Functions
# ============================================================================

# Add these 3 secrets in Supabase Dashboard:
# 
# 1. STRIPE_SECRET_KEY
#    Value: your_stripe_secret_key
#
# 2. STRIPE_WEBHOOK_SECRET
#    Value: your_stripe_webhook_secret
#    How to get: Stripe Dashboard → Developers → Webhooks → Add endpoint → Copy signing secret
#    Webhook URL: https://your-project.supabase.co/functions/v1/stripe-webhook
#
# 3. SUPABASE_SERVICE_ROLE_KEY
#    Value: your_supabase_service_role_key (Get this from Supabase Dashboard → Project Settings → API)
#    Look for "service_role" key and click to reveal it

# ============================================================================
# DEPLOYMENT CHECKLIST
# ============================================================================
# 
# FOR RENDER:
# ✓ Add all variables above (except SUPABASE_SERVICE_ROLE_KEY) in Render dashboard
# ✓ Make sure NODE_VERSION is set to 20.11.0
# ✓ All VITE_* variables must be present
#
# FOR SUPABASE EDGE FUNCTIONS:
# ✓ Deploy create-payment-intent function
# ✓ Deploy stripe-webhook function
# ✓ Add STRIPE_SECRET_KEY secret
# ✓ Add STRIPE_WEBHOOK_SECRET secret (after creating webhook in Stripe)
# ✓ Add SUPABASE_SERVICE_ROLE_KEY secret
#
# FOR STRIPE:
# ✓ Create webhook endpoint pointing to Supabase function
# ✓ Select events: payment_intent.succeeded, payment_intent.payment_failed, customer.subscription.deleted
# ✓ Copy webhook signing secret and add to Supabase
#
# ============================================================================
# SECURITY NOTES
# ============================================================================
# 
# ⚠️ YOU ARE USING LIVE STRIPE KEYS - Real payments will be processed!
# ⚠️ NEVER commit .env file to git - only commit .env.example
# ⚠️ VITE_* variables are exposed to browser - only put public keys here
# ⚠️ STRIPE_SECRET_KEY and SUPABASE_SERVICE_ROLE_KEY are sensitive - keep secure
# ⚠️ Service role key has full database access - only use in Edge Functions
#
# ============================================================================
